{
    "BatchUseDetectorMain": {
        "desc": "批量使用探物器/罗盘入口",
        "max_hit": 1,
        "anchor": {
            "ValuableStashValuablesTabInNext": "BatchUseDetectorFindWulingItem",
            "ValuableStashValuablesTabInNext2": "BatchUseDetectorFindValleyIVItem"
        },
        "next": [
            "[JumpBack]ValuableStashValuablesTab"
        ],
        "focus": {
            "Node.Action.Starting": "主任务启动"
        }
    },
    "BatchUseDetectorFindWulingItem": {
        "desc": "在珍贵物品页寻找武陵物品（template 由 Category 选项覆盖）",
        "enabled": true,
        "recognition": "TemplateMatch",
        "roi": [
            0,
            0,
            1280,
            720
        ],
        "template": "BatchUseDetector/wuling_detector.png",
        "threshold": 0.75,
        "order_by": "Score",
        "pre_wait_freezes": 500,
        "action": "Click",
        "post_wait_freezes": 300,
        "next": [
            "BatchUseDetectorConfirmWulingItemName"
        ],
        "focus": {
            "Node.Action.Starting": "寻找武陵物品"
        }
    },
    "BatchUseDetectorConfirmWulingItemName": {
        "desc": "OCR 确认武陵物品名称（expected 由 Category 选项覆盖）",
        "recognition": "OCR",
        "roi": [
            981,
            63,
            144,
            27
        ],
        "expected": [
            "武陵探物器"
        ],
        "threshold": 0.7,
        "next": [
            "BatchUseDetectorClickWhiteConfirmButton",
            "BatchUseDetectorFinished"
        ],
        "focus": {
            "Node.Action.Starting": "确认物品名称"
        }
    },
    "BatchUseDetectorFindValleyIVItem": {
        "desc": "在珍贵物品页寻找四号谷地物品（template 由 Category 选项覆盖）",
        "enabled": false,
        "recognition": "TemplateMatch",
        "roi": [
            0,
            0,
            1280,
            720
        ],
        "template": "BatchUseDetector/valleyiv_detector.png",
        "threshold": 0.75,
        "order_by": "Score",
        "pre_wait_freezes": 500,
        "action": "Click",
        "post_wait_freezes": 300,
        "next": [
            "BatchUseDetectorConfirmValleyIVItemName"
        ],
        "focus": {
            "Node.Action.Starting": "寻找四号谷地物品"
        }
    },
    "BatchUseDetectorConfirmValleyIVItemName": {
        "desc": "OCR 确认四号谷地物品名称（expected 由 Category 选项覆盖）",
        "recognition": "OCR",
        "roi": [
            981,
            63,
            144,
            27
        ],
        "expected": [
            "四号谷地探物器"
        ],
        "threshold": 0.7,
        "next": [
            "BatchUseDetectorClickWhiteConfirmButton",
            "BatchUseDetectorFinished"
        ],
        "focus": {
            "Node.Action.Starting": "确认物品名称"
        }
    },
    "BatchUseDetectorClickWhiteConfirmButton": {
        "desc": "点击详情页白色确认按钮",
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "WhiteConfirmButtonType1"
                ],
                "box_index": 0
            }
        },
        "action": "Click",
        "post_wait_freezes": 300,
        "next": [
            "BatchUseDetectorClickYellowConfirmButton"
        ]
    },
    "BatchUseDetectorClickYellowConfirmButton": {
        "desc": "点击详情页黄色确认按钮",
        "recognition": {
            "type": "And",
            "param": {
                "all_of": [
                    "YellowConfirmButtonType1"
                ],
                "box_index": 0
            }
        },
        "action": "Click",
        "post_wait_freezes": 500,
        "next": [
            "BatchUseDetectorBacktoValuablesTab"
        ]
    },
    "BatchUseDetectorBacktoValuablesTab": {
        "desc": "返回珍贵物品页，返回上一级",
        "action": "Click",
        "contact": 1,
        "post_wait_freezes": 400,
        "next": [
            "[JumpBack]BatchUseDetectorConfirmValleyIVItemName",
            "[JumpBack]BatchUseDetectorConfirmWulingItemName",
            "BatchUseDetectorFinished"
        ]
    },
    "BatchUseDetectorFinished": {
        "desc": "批量使用探物器/罗盘流程结束",
        "action": "StopTask",
        "focus": {
            "Node.Action.Starting": "主任务结束"
        }
    }
}
