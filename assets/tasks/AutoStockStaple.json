{
    "task": [
        {
            "name": "AutoStockStaple",
            "label": "$task.AutoStockStaple.label",
            "entry": "AutoStockStapleMain",
            "description": "$task.AutoStockStaple.description",
            "controller": [
                "Win32-Window",
                "Win32-Window-Background",
                "Win32-Front",
                "Wlroots"
            ],
            "group": [
                "daily"
            ],
            "option": [
                "AutoStockStapleValleyIV",
                "AutoStockStapleWuling"
            ]
        }
    ],
    "option": {
        "AutoStockStapleValleyIV": {
            "type": "switch",
            "label": "$task.AutoStockStaple.option.AutoStockStapleValleyIV.label",
            "description": "$task.AutoStockStaple.option.AutoStockStapleValleyIV.description",
            "default_case": "Yes",
            "cases": [
                {
                    "name": "Yes",
                    "pipeline_override": {
                        "AutoStockStapleValleyIV": {
                            "enabled": true
                        }
                    },
                    "option": [
                        "AutoStockReserveValleyIV",
                        "AutoStockBuyDailyGoodsValleyIV",
                        "AutoStockBuyStockFactoryGoodsValleyIV",
                        "AutoStockBuyCulturalGoodsValleyIV",
                        "AutoStockUseDiscountsValleyIV"
                    ]
                },
                {
                    "name": "No"
                }
            ]
        },
        "AutoStockReserveValleyIV": {
            "type": "input",
            "label": "$task.AutoStockStaple.option.AutoStockReserveValleyIV.label",
            "description": "$task.AutoStockStaple.option.AutoStockReserveValleyIV.description",
            "inputs": [
                {
                    "name": "ReserveValleyIV",
                    "label": "$task.AutoStockStaple.option.AutoStockReserveValleyIV.inputs.ReserveValleyIV.label",
                    "description": "$task.AutoStockStaple.option.AutoStockReserveValleyIV.inputs.ReserveValleyIV.description",
                    "pipeline_type": "int",
                    "verify": "^(?:[2-9][4-9]\\d{4}|[3-9]\\d{5}|[1-9]\\d{6,})$",
                    "default": "240000",
                    "pattern_msg": "$task.AutoStockStaple.option.AutoStockReserveValleyIV.inputs.ReserveValleyIV.pattern_msg"
                }
            ],
            "pipeline_override": {
                "AutoStockTargetCompareValleyIV": {
                    "recognition": {
                        "param": {
                            "custom_recognition_param": {
                                "expression": "{ReserveValleyIV}>{AutoStockCurrentStockBill}"
                            }
                        }
                    }
                }
            }
        },
