{
    "task": [
        {
            "name": "BatchUseDetector",
            "label": "$task.BatchUseDetector.label",
            "entry": "BatchUseDetectorMain",
            "description": "$task.BatchUseDetector.description",
            "option": [
                "BatchUseDetectorRegion",
                "BatchUseDetectorCategory",
                "BatchUseDetectorTimes"
            ],
            "controller": [
                "Win32-Window",
                "Win32-Front",
                "Wlroots"
            ],
            "group": [
                "utility"
            ]
        }
    ],
    "option": {
        "BatchUseDetectorRegion": {
            "type": "select",
            "label": "$task.BatchUseDetector.option.Region.label",
            "default_case": "Wuling",
            "cases": [
                {
                    "name": "Wuling",
                    "label": "$global.region.Wuling",
                    "pipeline_override": {
                        "BatchUseDetectorFindWulingItem": {
                            "enabled": true
                        },
                        "BatchUseDetectorConfirmWulingItemName": {
                            "enabled": true
                        },
                        "BatchUseDetectorFindValleyIVItem": {
                            "enabled": false
                        },
                        "BatchUseDetectorConfirmValleyIVItemName": {
                            "enabled": false
                        }
                    }
                },
                {
                    "name": "ValleyIV",
                    "label": "$global.region.ValleyIV",
                    "pipeline_override": {
                        "BatchUseDetectorFindWulingItem": {
                            "enabled": false
                        },
                        "BatchUseDetectorConfirmWulingItemName": {
                            "enabled": false
                        },
                        "BatchUseDetectorFindValleyIVItem": {
                            "enabled": true
                        },
                        "BatchUseDetectorConfirmValleyIVItemName": {
                            "enabled": true
                        }
                    }
                }
            ]
        },
        "BatchUseDetectorCategory": {
            "type": "select",
            "label": "$task.BatchUseDetector.option.Category.label",
            "default_case": "Detector",
            "cases": [
                {
                    "name": "Detector",
                    "label": "$task.BatchUseDetector.option.Category.Detector",
                    "pipeline_override": {
                        "BatchUseDetectorFindWulingItem": {
                            "template": "BatchUseDetector/wuling_detector.png"
                        },
                        "BatchUseDetectorConfirmWulingItemName": {
                            "expected": [
                                "武陵探物器"
                            ]
                        },
                        "BatchUseDetectorFindValleyIVItem": {
                            "template": "BatchUseDetector/valleyiv_detector.png"
                        },
                        "BatchUseDetectorConfirmValleyIVItemName": {
                            "expected": [
                                "谷地探物器"
                            ]
                        }
                    }
                },
                {
                    "name": "Compass",
                    "label": "$task.BatchUseDetector.option.Category.Compass",
                    "pipeline_override": {
                        "BatchUseDetectorFindWulingItem": {
                            "template": "BatchUseDetector/wuling_compass.png"
                        },
                        "BatchUseDetectorConfirmWulingItemName": {
                            "expected": [
                                "武陵罗盘"
                            ]
                        },
                        "BatchUseDetectorFindValleyIVItem": {
                            "template": "BatchUseDetector/valleyiv_compass.png"
                        },
                        "BatchUseDetectorConfirmValleyIVItemName": {
                            "expected": [
                                "谷地罗盘"
                            ]
                        }
                    }
                }
            ]
        },
        "BatchUseDetectorTimes": {
            "type": "input",
            "label": "$task.BatchUseDetector.option.Times.label",
            "inputs": [
                {
                    "name": "Times",
                    "label": "$task.BatchUseDetector.option.Times.input.label",
                    "default": "99",
                    "pipeline_type": "int",
                    "verify": "^[1-9]\\d*$",
                    "pattern_msg": "$task.BatchUseDetector.option.Times.input.error"
                }
            ],
            "pipeline_override": {
                "BatchUseDetectorClickWhiteConfirmButton": {
                    "max_hit": "{Times}"
                }
            }
        }
    }
}
